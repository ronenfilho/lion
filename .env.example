# ===========================================
# LLM PROVIDER CONFIGURATION
# ===========================================
# Provedor de LLM: gemini, openai, anthropic, ollama
LLM_PROVIDER=gemini

# API Keys (configure apenas a do provedor escolhido)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ===========================================
# MODEL CONFIGURATION
# ===========================================
# Modelos por provedor:
# - Gemini: gemini-2.0-flash-exp, gemini-1.5-pro, gemini-1.5-flash
# - OpenAI: gpt-4-turbo, gpt-4, gpt-3.5-turbo
# - Anthropic: claude-3-opus, claude-3-sonnet, claude-3-haiku
LLM_MODEL=gemini-2.0-flash-exp

# Parâmetros de geração
TEMPERATURE=0.2
MAX_TOKENS=800
TOP_P=0.95
TOP_K=40

# ===========================================
# EMBEDDINGS CONFIGURATION
# ===========================================
# Embedding provider: gemini, openai
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# ===========================================
# VECTOR STORE CONFIGURATION
# ===========================================
CHROMA_PERSIST_DIR=./data/vectorstore

# ===========================================
# RETRIEVAL CONFIGURATION
# ===========================================
TOP_K=5
SIMILARITY_THRESHOLD=0.7
USE_RERANKING=true
HYBRID_ALPHA=0.7

# ===========================================
# EVALUATION CONFIGURATION
# ===========================================
# LLM para RAGAS (usa OpenAI por padrão, ou configure para usar Gemini)
RAGAS_LLM_PROVIDER=gemini
RAGAS_API_KEY=your_gemini_key_here

# Monitoring
LOG_LEVEL=INFO
ENABLE_METRICS=true

# Cache
ENABLE_CACHE=true
CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.95
